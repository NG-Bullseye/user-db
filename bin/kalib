#!/usr/bin/env python3
"""kalib — algorithmische Stütze für die textuelle Kalibrierung des Interceptors.

Es gibt EINEN textuellen SOLL: das Wochen-Protokoll
(~/.config/user-db/wochen-protokoll.md). Kalibrierungen aus Leos Feedback
editiert der Manager DIREKT dort in der betroffenen Sektion — diese CLI macht
nur die zwei Dinge, die verlässlich maschinell laufen müssen:

  kalib intensity                             Soll-Grundlinie (JSON) zeigen
  kalib intensity <tag> <HH:MM> <wert> [--anlass "…"]
        Grundlinien-Fenster in soll-intensity.json ändern/einfügen (validiert,
        atomar; der Komparator liest pro Tick → wirkt sofort) + Log-Eintrag.
        Die Tabellen-Zelle im Protokoll-Text zieht der Manager selbst nach.
  kalib log "<Änderung>" [--anlass "…"]       Kalibrier-Log-Eintrag anhängen
        (Provenienz für rein textuelle Protokoll-Edits: was, wann, warum)

Das Kalibrier-Log ist eine Sektion AM ENDE des Wochen-Protokolls — Historie
für Leo und den Wochen-Diff, keine zweite Regelquelle.

σ-frei: reine SOLL-Textpflege, kein Policy-Key, kein Lernpfad.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
from datetime import date
from pathlib import Path

USER_DB_DIR = Path(os.environ.get("USER_DB_DIR", "~/.config/user-db")).expanduser()
PROTOKOLL_FILE = USER_DB_DIR / "wochen-protokoll.md"
SOLL_FILE = USER_DB_DIR / "soll-intensity.json"

DAYS = ("mo", "di", "mi", "do", "fr", "sa", "so")
LOG_HEADER = "## Kalibrier-Log — Leos Feedback → Protokoll-Änderungen (Manager-geführt, via `kalib`)"
LOG_ENTRY_RE = re.compile(r"^- \*\*\d{4}-\d{2}-\d{2} (K-\d{3})\*\*", re.M)


def _append_log(aenderung: str, anlass: str | None) -> str:
    text = PROTOKOLL_FILE.read_text()
    if LOG_HEADER not in text:
        text = text.rstrip("\n") + f"\n\n{LOG_HEADER}\n"
    nums = [int(m.group(1)[2:]) for m in LOG_ENTRY_RE.finditer(text)]
    kid = f"K-{(max(nums) + 1) if nums else 1:03d}"
    line = f"- **{date.today().isoformat()} {kid}** {aenderung}"
    if anlass:
        line += f" *(Anlass: {anlass})*"
    tmp = PROTOKOLL_FILE.with_suffix(".md.tmp")
    tmp.write_text(text.rstrip("\n") + "\n" + line + "\n")
    tmp.replace(PROTOKOLL_FILE)
    return kid


def cmd_log(args: argparse.Namespace) -> None:
    kid = _append_log(args.aenderung, args.anlass)
    print(f"{kid} ins Kalibrier-Log geschrieben — die inhaltliche Protokoll-Sektion "
          "selbst editieren nicht vergessen (das Log ist nur Provenienz).")


def cmd_intensity(args: argparse.Namespace) -> None:
    data = json.loads(SOLL_FILE.read_text())
    days = data["days"]
    if args.tag is None:  # nur anzeigen
        for day in DAYS:
            windows = " ".join(f"{s}={v}" for s, v in days.get(day, []))
            print(f"{day}: {windows}")
        return
    tag = args.tag.lower()
    if tag not in DAYS:
        sys.exit(f"Unbekannter Tag '{tag}' — erwartet: {', '.join(DAYS)}")
    if not re.fullmatch(r"([01]\d|2[0-3]):[0-5]\d", args.zeit):
        sys.exit(f"Ungültige Zeit '{args.zeit}' — erwartet HH:MM.")
    if not 0 <= args.wert <= 100:
        sys.exit("Wert muss 0–100 sein.")
    windows = days[tag]
    old = next((v for s, v in windows if s == args.zeit), None)
    if old is not None:
        windows[:] = [[s, args.wert if s == args.zeit else v] for s, v in windows]
        change = f"Grundlinie {tag} {args.zeit}: {old} → {args.wert}"
    else:
        windows.append([args.zeit, args.wert])
        windows.sort(key=lambda w: w[0])
        change = f"Grundlinie {tag} {args.zeit}: neues Fenster, Wert {args.wert}"
    tmp = SOLL_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n")
    tmp.replace(SOLL_FILE)
    kid = _append_log(change + " (soll-intensity.json maschinell nachgezogen)", args.anlass)
    print(f"{kid}: {change} — live ab nächster Komparator-Minute. "
          "Protokoll-Tabelle (§ Soll-Raumintensität) selbst nachziehen.")


def main() -> None:
    parser = argparse.ArgumentParser(prog="kalib", description=__doc__,
                                     formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_log = sub.add_parser("log", help="Kalibrier-Log-Eintrag (Provenienz) anhängen")
    p_log.add_argument("aenderung")
    p_log.add_argument("--anlass", help="welche neuronale Entscheidung war schlecht (Leo-Feedback)")
    p_log.set_defaults(func=cmd_log)

    p_int = sub.add_parser("intensity", help="Soll-Grundlinie zeigen/ändern (JSON-Sync + Log)")
    p_int.add_argument("tag", nargs="?", help="mo|di|mi|do|fr|sa|so")
    p_int.add_argument("zeit", nargs="?", help="HH:MM Fensterstart")
    p_int.add_argument("wert", nargs="?", type=int, help="Grundlinie 0–100")
    p_int.add_argument("--anlass")
    p_int.set_defaults(func=cmd_intensity)

    args = parser.parse_args()
    if args.cmd == "intensity" and args.tag is not None and (args.zeit is None or args.wert is None):
        parser.error("intensity braucht tag zeit wert (oder gar keine Argumente zum Anzeigen)")
    args.func(args)


if __name__ == "__main__":
    main()
